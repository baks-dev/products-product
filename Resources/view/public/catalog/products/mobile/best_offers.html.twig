{# БЛОК ЛУЧШИЕ ПРЕДЛОЖЕНИЯ #}

<div class="pt-2 mb-3">
    <h3 class="fs-18 text-uppercase fw-bold" style="margin-bottom: 30px">
        Лучшие предложения {{ category.category_name }}
    </h3>
    <ol class="list-group list-group-numbered rounded-4 p-2" style="background-color: #fff4d8;">

        {% for offer in bestOffers %}
            <li class="list-group-item  best-offers-item border-0 list-group-item-action bg-transparent"
                style="width: max-content;">
                <a class="text-black text-decoration-none"
                   href="{{ path('products-product:public.model', {
                       category: offer.category_url,
                       url: offer.url
                   }) }}">
                    {{ offer.product_name }}
                </a></li>
        {% endfor %}

    </ol>
</div>

