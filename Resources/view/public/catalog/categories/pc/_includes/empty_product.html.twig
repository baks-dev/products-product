{# Обложка продукта #}
{% set image_path = '/assets/'~version~'/img/blank.svg' %}

<div class="col p-1 px-2">
    <div class="card border-0 position-relative p-1 rounded-4 h-100">

        {# Изображение #}
        <div class="card-img-top rounded-4 border ratio ratio-1x1"
             style="background: url({{ image_path }}) center/contain no-repeat;">
        </div>

        <div class="d-flex flex-column justify-content-between card-body pb-1 px-0">

            <div>
                <div class="d-flex align-items-center justify-content-between mb-2 px-3">

                    {# Цена (placeholder) #}
                    <div class="placeholder-glow w-50">
                        <span class="placeholder bg-secondary-subtle rounded-pill"
                              style="height: 2rem; display: block;">
                        </span>
                    </div>

                </div>
            </div>

            {# Название #}
            <div class="d-flex mb-2">
                <div class="px-3 w-100">

                    <div class="placeholder-glow">
                    <span class="placeholder col-8 bg-secondary-subtle rounded mb-2"
                          style="height: 1.2rem; display: block;"></span>

                        <span class="placeholder col-6 bg-secondary-subtle rounded"
                              style="height: 1rem; display: block;"></span>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>
