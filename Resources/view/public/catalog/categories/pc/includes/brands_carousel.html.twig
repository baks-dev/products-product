{# КАРУСЕЛЬ БРЕНДОВ #}

<div class="d-flex align-items-center mb-4">
    <h2 class="visually-hidden">Карусель и логотипами брендов</h2>
    <div class="scroll-shadow"></div>

    <div class="d-flex align-items-center gap-0 overflow-x-auto invisibility-scroll ticker-animate"
         id="scroll-container">

        {% for category in categories %}

            {# Обложка категории #}
            {% set categoryCover = '/assets/{{ version}}/img/blank.svg' %}
            {% if category.category_cover_ext is defined and category.category_cover_ext is not null %}
                {% set img_host = category.category_cover_cdn == true  ? CDN_HOST : '' %}
                {% set img_dir = category.category_cover_image %}
                {% set img_file = (img_host is empty ? '/image.' : '/small.') ~ category.category_cover_ext %}
                {% set categoryCover = img_host ~ img_dir ~ img_file %}
            {% endif %}

            <img
                    src="/assets/{{ version }}/img/empty.png"
                    data-src="{{ categoryCover }}"
                    alt="{{ category.category_name }}"
                    draggable="false"
                    style="width:200px; height:100%"
                    class="me-2 lazy"
            >

        {% endfor %}

        {% for category in categories %}

            {# Обложка категории #}
            {% set categoryCover = '/assets/{{ version}}/img/blank.svg' %}
            {% if category.category_cover_ext is defined and category.category_cover_ext is not null %}
                {% set img_host = category.category_cover_cdn == true  ? CDN_HOST : '' %}
                {% set img_dir = category.category_cover_image %}
                {% set img_file = (img_host is empty ? '/image.' : '/small.') ~ category.category_cover_ext %}
                {% set categoryCover = img_host ~ img_dir ~ img_file %}
            {% endif %}

            <img
                    src="/assets/{{ version }}/img/empty.png"
                    data-src="{{ categoryCover }}"
                    alt="{{ category.category_name }}"
                    draggable="false"
                    style="width:200px; height:100%"
                    class="me-2 lazy"
            >

        {% endfor %}
    </div>

    <div class="scroll-shadow"></div>
</div>

