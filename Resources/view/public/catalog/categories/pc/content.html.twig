<main>

    {# категории #}
    {{ include(_self|replace({ "content.html.twig" : "_includes/categories.html.twig" }), {'categories': categories }) }}

    {# фильтр по параметрам продукции #}
    {% if filter_tire.offer is defined %}
        {{ include(_self|replace({ "content.html.twig": "_includes/filter.html.twig" })) }}
    {% endif %}

    {# спиннеры загрузки #}
    <section class="container py-3">

        <div id="catalog_products_spinners">
            {% for i in 1..3 %}
                <div class="spinner-grow text-primary ms-2 me-2" role="status">
                </div>
            {% endfor %}
        </div>

    </section>

    {# каталог продукции #}
    <section class="container py-3">

        <div id="catalog_products"></div>

        <div id="catalog_products_preload">
            {% for i in 1..3 %}

                <div class="row">

                    <div class="col-9 ">

                        <div class="placeholder-glow mb-3">
                        <span class="placeholder bg-secondary-subtle rounded-pill"
                              style="height: 2rem; width: 10rem; display: block;">
                        </span>
                        </div>

                        {# карточки продукции #}
                        <div class="row row-cols-4 mb-4">

                            {% for i in 1..4 %}

                                {{ include(_self|replace({ "content.html.twig": "_includes/empty_product.html.twig" })) }}

                            {% endfor %}

                        </div>

                    </div>

                    {# лидеры продаж #}
                    <div class="col-3 ">
                        <div class="pt-2 ">

                            <div class="placeholder-glow mb-3">
                                <span class="placeholder bg-secondary-subtle rounded-pill"
                                      style="height: 2rem; width: 10rem; display: block;">
                                </span>
                            </div>

                            <ol class="list-group list-group-numbered rounded-4 p-3" style="background-color: #fff4d8;">

                                {% for i in 1..5 %}
                                    &nbsp;

                                    <div class="placeholder-glow">
                                    <span class="placeholder bg-warning rounded-pill"
                                          style="height: 2rem; width: {{ random(3..15) }}rem; display: block;">
                                    </span>
                                    </div>
                                {% endfor %}

                            </ol>
                        </div>
                    </div>

                </div>

            {% endfor %}
        </div>
    </section>

    {# шаблон пустого результата #}
    <section id="catalog_products_empty" class="container py-3 d-none">

        <div>
            <h2 class="fs-18 mb-0 text-uppercase fw-bold ">
                Товар по выбранным параметрам не найден

                <a href="/refresh" class="btn btn-link text-muted">
                    <button class="btn bg-primary fw-bold rounded-3 w-100 text-dark">

                        <svg class="w-6 h-6 text-gray-800 dark:text-white" aria-hidden="true"
                             xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none"
                             viewBox="0 0 24 24">
                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"
                                  stroke-width="2"
                                  d="M17.651 7.65a7.131 7.131 0 0 0-12.68 3.15M18.001 4v4h-4m-7.652 8.35a7.13 7.13 0 0 0 12.68-3.15M6 20v-4h4"></path>
                        </svg>

                    </button>
                </a>

            </h2>
        </div>

    </section>

    {# карусель логотипов брендов #}
    <section class="container py-3">
        {% include Template('/public/'~baks_settings.device~'/_includes/brands_carousel.html.twig') %}
    </section>

</main>

